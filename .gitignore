# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# TEMPORARY: the local dev npm mirror is inconsistent and produces a poisoned
# lockfile (see AB#1235). Ignored until a clean package-lock.json is generated
# against the real registry (first Vercel/CI install), after which it should be
# committed and CI switched to `npm ci`.
/package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Convex generated code is committed so CI (type-check/test/build) resolves the
# generated API/dataModel types without a deploy key. Regenerate with
# `npx convex codegen` after changing the schema or function signatures.
# The ai/ subdir is local AI-tooling cruft, not app code.
convex/_generated/ai/

# clerk CLI / skills tooling (not app code)
.agents/
.claude/
.vscode/
skills-lock.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
