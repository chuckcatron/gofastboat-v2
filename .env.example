# Convex
NEXT_PUBLIC_CONVEX_URL=

# Clerk (web auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Set as Convex env vars (npx convex env set), not here:
#   CLERK_JWT_ISSUER_DOMAIN  - Clerk issuer, required by convex/auth.config.ts for JWT validation
#   ADMIN_EMAILS             - optional, comma-separated allowlist for convex/lib/auth.ts requireAdmin
#                              (when unset, any authenticated Clerk identity is treated as admin)
